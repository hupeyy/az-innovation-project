# =================================================================
# AZ Data Pipeline - Environment Configuration Template
# 1. Copy this file to '.env'
# 2. Fill in the values with your actual credentials
# =================================================================


# -----------------------------------------------------------------
# API Keys
# -----------------------------------------------------------------
OPENWEATHER_API_KEY=your_openweather_api_key_here
NEWS_API_KEY=your_newsapi_key_here
ALPHAVANTAGE_API_KEY=your_alphavantage_api_key_here


# -----------------------------------------------------------------
# GCP BigQuery Settings
# -----------------------------------------------------------------
BIGQUERY_PROJECT_ID=your_gcp_project_id
DATASET_ID=az_innovation_dataset

# Path to your Google Service Account JSON key file
# Place the file in the project root and reference it here
GOOGLE_CREDENTIALS_JSON=service_account_key.json


# -----------------------------------------------------------------
# Google Sheets Logging
# -----------------------------------------------------------------
GOOGLE_SHEETS_ID=your_google_sheet_id_here


# -----------------------------------------------------------------
# Gmail Notifications (Used for failure alerts)
# -----------------------------------------------------------------
GMAIL_ADDRESS=your_email@gmail.com
GMAIL_APP_PASSWORD=your_16_character_app_password
ALERT_EMAIL=your_email@gmail.com